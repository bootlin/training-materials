From d181185ed56b8e38ca553833ccc153b63ae0a7fd Mon Sep 17 00:00:00 2001
From: Olivier Benjamin <olivier.benjamin@bootlin.com>
Date: Sat, 9 May 2026 09:58:52 +0200
Subject: [PATCH] Boot from rootfs A in A/B setup

This is not yet booting using the A/B setup, as we are not
using a boot script that takes advantage of it, but it is
booting using the A rootFS slot.

Signed-off-by: Olivier Benjamin <olivier.benjamin@bootlin.com>
---
 board/nxp/imx93_frdm/imx93_frdm.env | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/board/nxp/imx93_frdm/imx93_frdm.env b/board/nxp/imx93_frdm/imx93_frdm.env
index 67e395a47bef..007ee01d6858 100644
--- a/board/nxp/imx93_frdm/imx93_frdm.env
+++ b/board/nxp/imx93_frdm/imx93_frdm.env
@@ -11,7 +11,7 @@ fdtfile=CONFIG_DEFAULT_FDT_FILE
 mmcautodetect=yes
 emmc_dev=0
 sd_dev=1
-mmcargs=setenv bootargs console=${console} root=/dev/mmcblk${sd_dev}p2 selinux=1 enforcing=0 rootwait
+mmcargs=setenv bootargs console=${console} root=/dev/mmcblk${sd_dev}p3 selinux=1 enforcing=0 rootwait
 kernel_addr_r=CONFIG_SYS_LOAD_ADDR
 fastboot_partition_alias_all=0:0
 fastboot_partition_alias_bootloader=0.1
-- 
2.47.3


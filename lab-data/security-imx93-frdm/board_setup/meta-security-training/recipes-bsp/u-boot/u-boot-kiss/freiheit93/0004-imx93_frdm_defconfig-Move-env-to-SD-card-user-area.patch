From 169c0ef66338e0162ab14ede3c75e283f4c51b65 Mon Sep 17 00:00:00 2001
From: Olivier Benjamin <olivier.benjamin@bootlin.com>
Date: Mon, 27 Apr 2026 16:37:26 +0200
Subject: [PATCH 06/13] imx93_frdm_defconfig: Move env to SD card user area

Signed-off-by: Olivier Benjamin <olivier.benjamin@bootlin.com>
---
 board/freescale/imx93_frdm/imx93_frdm.env |  8 ++++++--
 configs/imx93_frdm_defconfig              | 17 ++++++++++-------
 2 files changed, 16 insertions(+), 9 deletions(-)

diff --git a/board/freescale/imx93_frdm/imx93_frdm.env b/board/freescale/imx93_frdm/imx93_frdm.env
index f845c2865c4..079a07877d5 100644
--- a/board/freescale/imx93_frdm/imx93_frdm.env
+++ b/board/freescale/imx93_frdm/imx93_frdm.env
@@ -11,10 +11,14 @@ fdtfile=CONFIG_DEFAULT_FDT_FILE
 mmcautodetect=yes
 emmc_dev=0
 sd_dev=1
-mmcargs=setenv bootargs console=${console} root=/dev/mmcblk${sd_dev}p1 selinux=1 enforcing=0 rootwait
+mmcargs=setenv bootargs console=${console} root=/dev/mmcblk${sd_dev}p2 selinux=1 enforcing=0 rootwait
 kernel_addr_r=CONFIG_SYS_LOAD_ADDR
 fastboot_partition_alias_all=0:0
 fastboot_partition_alias_bootloader=0.1
 dofastboot=0
-bsp_bootcmd=run mmcargs; mmc read 0x83000000 0x4000 0x80000; iminfo 0x83000000; bootm 0x83000000
+/* The first partition is for imx-boot (the AHAB container). It stops at 8MiB,
+ * then 2 MiB are reserved for the U-Boot env. The raw FIT image to be loaded
+ * starts there, so 20 * 1024 = 20480 (0x5000) 512-byte sectors.
+ */
+bsp_bootcmd=run mmcargs; mmc read 0x83000000 0x5000 0x80000; iminfo 0x83000000; bootm 0x83000000
 scriptaddr=0x83500000
diff --git a/configs/imx93_frdm_defconfig b/configs/imx93_frdm_defconfig
index 4861af5a8d0..bc5bc44d638 100644
--- a/configs/imx93_frdm_defconfig
+++ b/configs/imx93_frdm_defconfig
@@ -6,8 +6,6 @@ CONFIG_SYS_MALLOC_F_LEN=0x18000
 CONFIG_SPL_LIBCOMMON_SUPPORT=y
 CONFIG_SPL_LIBGENERIC_SUPPORT=y
 CONFIG_NR_DRAM_BANKS=2
-CONFIG_ENV_SIZE=0x4000
-CONFIG_ENV_OFFSET=0x700000
 CONFIG_IMX_CONFIG="arch/arm/mach-imx/imx9/imximage.cfg"
 CONFIG_DM_GPIO=y
 CONFIG_DEFAULT_DEVICE_TREE="imx93-11x11-frdm"
@@ -81,11 +79,6 @@ CONFIG_CMD_SPAWN=y
 CONFIG_CMD_READ=y
 CONFIG_OF_CONTROL=y
 CONFIG_SPL_OF_CONTROL=y
-CONFIG_ENV_OVERWRITE=y
-CONFIG_ENV_IS_NOWHERE=y
-CONFIG_ENV_IS_IN_MMC=y
-CONFIG_ENV_RELOC_GD_ENV_ADDR=y
-CONFIG_ENV_VARS_UBOOT_RUNTIME_CONFIG=y
 CONFIG_SPL_DM=y
 CONFIG_REGMAP=y
 CONFIG_SYSCON=y
@@ -139,3 +132,13 @@ CONFIG_BZIP2=y
 CONFIG_UTHREAD=y
 
 CONFIG_FIT=y
+
+CONFIG_ENV_IS_NOWHERE=y
+CONFIG_ENV_IS_IN_MMC=y
+CONFIG_SYS_MMC_ENV_DEV=1
+CONFIG_SYS_MMC_ENV_PART=0
+CONFIG_ENV_SIZE=0x200000
+CONFIG_ENV_OFFSET=0x800000
+CONFIG_ENV_OVERWRITE=y
+CONFIG_ENV_VARS_UBOOT_RUNTIME_CONFIG=y
+CONFIG_ENV_RELOC_GD_ENV_ADDR=y
-- 
2.43.0


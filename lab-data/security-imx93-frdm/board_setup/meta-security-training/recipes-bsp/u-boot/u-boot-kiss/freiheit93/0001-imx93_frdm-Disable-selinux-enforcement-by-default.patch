From 5f6165d312f21b14a5dfde81c9bb0fda716b09f1 Mon Sep 17 00:00:00 2001
From: Mathieu Dubois-Briand <mathieu.dubois-briand@bootlin.com>
Date: Tue, 17 Mar 2026 09:39:24 +0100
Subject: [PATCH] imx93_frdm: Disable selinux enforcement by default

Signed-off-by: Mathieu Dubois-Briand <mathieu.dubois-briand@bootlin.com>
---
 board/freescale/imx93_frdm/imx93_frdm.env | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/board/freescale/imx93_frdm/imx93_frdm.env b/board/freescale/imx93_frdm/imx93_frdm.env
index 111f38ed72a6..a9162d1e3e4d 100644
--- a/board/freescale/imx93_frdm/imx93_frdm.env
+++ b/board/freescale/imx93_frdm/imx93_frdm.env
@@ -14,7 +14,7 @@ mmcdev=1
 mmcpart=1
 mmcroot=/dev/mmcblk${mmcdev}p2 rootwait rw
 mmcautodetect=yes
-mmcargs=setenv bootargs console=${console} root=${mmcroot}
+mmcargs=setenv bootargs console=${console} root=${mmcroot} selinux=1 enforcing=0
 kernel_addr_r=CONFIG_SYS_LOAD_ADDR
 loadimage=load mmc ${mmcdev}:${mmcpart} ${loadaddr} ${image}
 loadfdt=load mmc ${mmcdev}:${mmcpart} ${fdt_addr_r} ${fdtfile}
-- 
2.47.3


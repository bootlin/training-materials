% Create an encirclement around all sections name
\newcommand*\round[2]{%
	\tikz[baseline=(char.base)]\node[anchor=north west, draw,rectangle, rounded corners, inner sep=2.5pt, minimum size=5.5mm, text height=3.6mm, fill=#2,#2,text=white](char){#1};%
}
\renewcommand{\section}[1]{
	{
		\color{gray}
		\Large\round{#1}{blorange}
	}
}

